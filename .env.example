# ==================== ОКРУЖЕНИЕ ====================
ENV=development

# ==================== MONGODB ====================
MONGODB_USER=root
MONGODB_PASSWORD=example
MONGODB_HOST=localhost 
MONGODB_PORT=27017
DATABASE_NAME=wagon_db

# ==================== API ====================
API_TITLE=Wagon ML API - Clean Architecture
API_VERSION=2.0.0
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ==================== ЗАГРУЗКА ФАЙЛОВ ====================
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads

# ==================== ML-МОДЕЛИ ====================
MODEL1_PATH=./NN_models/model-1.pt
MODEL2_PATH=./NN_models/model-2.pt
MODEL_TIMEOUT=30

# ==================== ХРАНИЛИЩЕ ФОТОГРАФИЙ ====================
PHOTOS_BASE_PATH=./result

# ==================== ЛОГИРОВАНИЕ ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ==================== РЕЗУЛЬТАТЫ MODEL-1 ====================
OUTPUT_MODEL1_PATH=./results/model1
