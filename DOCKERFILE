FROM python:3.10-slim

WORKDIR /app

# Установка uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Системные зависимости для OpenCV, torch и других ML библиотек
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Копируем requirements и устанавливаем зависимости через uv
COPY microservise/requirements.txt .
RUN uv pip install --system --no-cache -r requirements.txt

# Копируем код микросервиса
COPY microservise/ .

# Копируем ML модели
COPY microservise/NN_models/ ./NN_models/

# Создаем директории для результатов и временного хранилища
RUN mkdir -p /app/results /app/photo_aggregate /app/logs

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health').read()" || exit 1

EXPOSE 8000

# Запуск приложения с логированием
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]